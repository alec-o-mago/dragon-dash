	update_progress_bar("progress_bar_5_", global.level_luck)
	local egg_icon = gui.get_node("egg_icon5")
	local egg_label = gui.get_node("eggs_label5")
	local visible  = (global.level_luck<7)
	gui.set_visible(egg_icon, visible)
	gui.set_visible(egg_label, visible)
	if visible then
		gui.set_text(egg_label, tostring(global.UPGRADE_COST[global.level_luck+1]))
	end
end

local function update_progress_bars()
	update_health_ui()
	update_power_ui()
	update_quantity_ui()
	update_speed_ui()
	update_luck_ui()
end

function init(self)
	msg.post(".", "acquire_input_focus")
	gui.set_text(gui.get_node("gold_label"), global.gold)
	gui.set_text(gui.get_node("eggs_label"), global.eggs)
	update_progress_bars()
end

function on_message(self, message_id, message, sender)
	--
end

function on_input(self, action_id, action)
	local menu_button = gui.get_node("menu_button")
	if action_id == hash("touch") and action.pressed then
		if gui.pick_node(menu_button, action.x, action.y) then
			msg.post("main:/go", "load_main_menu")
		end
	end
end
