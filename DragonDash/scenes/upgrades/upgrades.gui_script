-- upgrades.gui_script

local global = require("main.global")

-- Helper function to update any progress bar
local function update_progress_bar(bar_prefix, level_value)
	for i = 1, 7 do
		local node = gui.get_node(bar_prefix .. i)
		if level_value >= i then
			gui.set_color(node, global.RAINBOW_COLORS[i])
		else
			gui.set_color(node, global.COLOR_GRAY_TRANSPARENT)
		end
	end
end

local function update_health_ui()
	update_progress_bar("progress_bar_1_", global.level_health)
	local egg_icon = gui.get_node("egg_icon1")
	local egg_label = gui.get_node("eggs_label1")
	local visible  = (global.level_health<7)
	gui.set_visible(egg_icon, visible)
	gui.set_visible(egg_label, visible)
	if visible then
		gui.set_text(egg_label, tostring(global.UPGRADE_COST[global.level_health+1]))
	end
end

local function update_power_ui()
	update_progress_bar("progress_bar_2_", global.level_power)
	local egg_icon = gui.get_node("egg_icon2")
	local egg_label = gui.get_node("eggs_label2")
