-- eggs.gui_script


local enable_leave = false

function init(self)
	msg.post(".", "acquire_input_focus")
	timer.delay(1, false, function()
		enable_leave = true
	end)
end

function on_input(self, action_id, action)
	if action_id == hash("touch") and action.pressed and enable_leave then
		msg.post("main:/go", "load_main_menu")
	end
end
